" highlight matched
set hlsearch
" case insensitive search
set ignorecase
set smartcase
" search while typing
set incsearch
" wrap-around when searching
set wrapscan
" show pressed keys in lower right corner
set showcmd
" tab -> spaces
set expandtab
set tabstop=4
set shiftwidth=4
" keep a 5 line buffer for the cursor from top/bottom of window
set scrolloff=5
" X11 clipboard
set clipboard=unnamedplus
" use ~ with movement
" set tildeop

" mappings
nnoremap ; :
noremap <C-s> :w<CR>
inoremap <C-s> <ESC>:w<CR>
" reselect visual block after indent
vnoremap < <gv
vnoremap > >gv

" qt creator
noremap gd :gotodec<CR>
noremap gD :gotodef<CR>
noremap gr :gotorefs<CR>
noremap <Space>lf :formatdoc<CR>
noremap <Space>lr :rename<CR>
noremap <Space>fw :findadv<CR>
" noremap <Space>ff :findfiles<CR>
noremap <Space>r :run<CR>
noremap <Space>d :debug<CR>
noremap <Space>h :nohls<CR>
noremap <C-p> :findfiles<CR>
inoremap <C-p> <ESC>:findfiles<CR>

" MOVE LINE/BLOCK
"nnoremap <C-S-J> :m+<CR>==
"nnoremap <C-S-K> :m-2<CR>==
"inoremap <C-S-J> <Esc>:m+<CR>==gi
"inoremap <C-S-K> <Esc>:m-2<CR>==gi
